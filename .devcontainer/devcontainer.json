{
  "image": "mcr.microsoft.com/devcontainers/python:3.11",
  "features": {
    "ghcr.io/devcontainers-extra/features/spark-sdkman:2": {
      "version": "3.5.1",           
      "jdkVersion": "17.0.12-tem",  
      "jdkDistro": "tem"         
    }
  },
  "updateContentCommand": "python3 -m pip install -r requirements.txt",
  "postCreateCommand": "java -version && echo JAVA_HOME=$JAVA_HOME && python - <<'PY'\nimport os, pyspark; print('pyspark', pyspark.__version__); print('JAVA_HOME', os.environ.get('JAVA_HOME'))\nPY",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-toolsai.jupyter",
        "GitHub.copilot",
        "ms-python.python",
        "ms-python.debugpy",
        "ms-python.vscode-pylance",
        "ms-toolsai.vscode-jupyter-slideshow",
        "ms-toolsai.jupyter-renderers",
        "ms-toolsai.vscode-jupyter-cell-tags"
      ]
    }
  }
}
